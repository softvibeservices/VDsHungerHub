generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// -----------------------------------------
// APP USER (unified login -- Admin + Staff)
// -----------------------------------------
enum AppRole {
  ADMIN
  STAFF
  CUSTOMER
}

model AppUser {
  id        String   @id @default(cuid())
  name      String
  number    String   @unique // 10-digit mobile, used as username
  password  String           // bcrypt hashed
  role      AppRole  @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------
// ADMIN (legacy -- kept for backwards compat)
// -----------------------------------------
model Admin {
  id        String   @id @default(cuid())
  name      String
  number    String   @unique
  password  String   // bcrypt hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------
// COMPANY STATUS ENUM
// -----------------------------------------
enum CompanyStatus {
  PENDING    // not yet shown in dropdown or admin dashboard
  CONFIRMED  // visible everywhere, once the adding user verifies OTP
}

// -----------------------------------------
// COMPANIES
// -----------------------------------------
model Company {
  id             String        @id @default(cuid())
  name           String        @unique
  location       String?
  isActive       Boolean       @default(true)
  // New fields for customer self-registration
  status         CompanyStatus @default(CONFIRMED) // CONFIRMED for admin-created, PENDING for customer-created
  addedByUserId  String?       // which User's registration triggered creation
  addedByUser    User?         @relation("CompanyAddedBy", fields: [addedByUserId], references: [id])
  confirmedAtUtc DateTime?     // when status flipped to CONFIRMED
  isVerifiedByAdmin Boolean   @default(false)
  isFlaggedFake     Boolean   @default(false)
  flaggedReason     String?
  users          User[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum UserStatus {
  ACTIVE
  BLOCKED
  BANNED
}

// -----------------------------------------
// ADDRESS TYPE
// -----------------------------------------
enum AddressType {
  WORK
  HOME
}

// -----------------------------------------
// USERS (Tiffin Customers)
// -----------------------------------------
model User {
  id         String   @id @default(cuid())
  name       String
  number     String   @unique // WhatsApp number -- used as PK for ordering
  company    Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId  String?  // null until OTP verified (company created in verify-otp step)
  isActive   Boolean  @default(true)

  // Customer self-registration fields
  workAddress       String?
  homeAddress       String?
  isVerified        Boolean   @default(false) // false until OTP verified
  verifiedAt        DateTime?

  // companyNameManual: typed company name held here until OTP verification succeeds.
  // At OTP verify time this is converted to a real Company row and cleared.
  // NEVER persisted as a Company row while the user is still unverified.
  companyNameManual String?

  // PIN-based login
  pinHash           String?   // bcrypt hash of 6-digit PIN, null until set
  pinFailedAttempts Int       @default(0)
  pinLockedUntil    DateTime?

  // Admin-only geolocation (never sent to customer API)
  latitude  Float?
  longitude Float?

  // Block/Ban features
  status            UserStatus @default(ACTIVE)
  statusReason      String?
  statusChangedAt   DateTime?
  banHistory        BanHistory[]
  companiesAdded    Company[]  @relation("CompanyAddedBy")

  devices            UserDevice[]
  deviceFingerprints DeviceFingerprint[]
  sessions           CustomerSession[]
  orders             Order[]
  addresses          Address[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isVerified])
  @@index([status])
  @@index([companyId])
}

// -----------------------------------------
// ADDRESS (user delivery addresses)
// -----------------------------------------
model Address {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AddressType
  line1     String
  line2     String?
  landmark  String?
  city      String?
  pincode   String?
  isDefault Boolean     @default(false)
  orders    Order[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

// -----------------------------------------
// PRODUCTS (Raw items -- sabji, roti, dal, rice, etc.)
// -----------------------------------------
model Product {
  id               String  @id @default(cuid())
  name             String  @unique
  nameGu           String?
  quantity         String  // e.g. "4 pieces", "1 bowl", "250ml"
  price            Float   // price per unit / per item
  isActive         Boolean @default(true)
  isAddOnAvailable Boolean @default(false)

  thaliSabjiPool    ThaliSabjiProduct[]
  dailySabjiOptions DailyMenuSabjiOption[]
  orderSabji        OrderSabji[]
  orderAddons       OrderAddon[]
  orderThaliItems   OrderThaliItem[]
  orderAddonItems   OrderAddonItem[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// -----------------------------------------
// THALI CATEGORIES
// -----------------------------------------
model ThaliCategory {
  id        String  @id @default(cuid())
  name      String  @unique // e.g. "Gujarati Thali"
  nameGu    String? // e.g. "gujarati thali"
  isActive  Boolean @default(true)

  thalis         Thali[]
  dailySabjiOpts DailyMenuSabjiOption[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// -----------------------------------------
// THALIS (Meal combinations)
// -----------------------------------------
model Thali {
  id          String  @id @default(cuid())
  name        String  @unique // e.g. "Small Gujarati Thali"
  nameGu      String?
  price       Float
  description String? // Short description for reference
  sabjiCount  Int     @default(1) // How many sabji user must choose
  isActive    Boolean @default(true)
  category    ThaliCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId  String?

  items           ThaliItem[]         // Fixed items (roti, dal, rice, salad, etc.)
  sabjiPool       ThaliSabjiProduct[]
  dailyMenus      DailyMenuThali[]
  orders          Order[]
  orderThaliItems OrderThaliItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Fixed components of a thali (non-sabji items)
model ThaliItem {
  id        String   @id @default(cuid())
  thali     Thali    @relation(fields: [thaliId], references: [id], onDelete: Cascade)
  thaliId   String
  itemName  String   // e.g. "4 Roti", "Dal", "Rice", "Salad", "Buttermilk"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([thaliId, itemName])
}

// -----------------------------------------
// THALI SABJI POOL
// -----------------------------------------
model ThaliSabjiProduct {
  id        String   @id @default(cuid())
  thali     Thali    @relation(fields: [thaliId], references: [id], onDelete: Cascade)
  thaliId   String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())

  @@unique([thaliId, productId])
}

// -----------------------------------------
// STAFF
// -----------------------------------------
model Staff {
  id        String   @id @default(cuid())
  name      String
  number    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------
// DAILY MENU
// -----------------------------------------
model DailyMenu {
  id         String    @id @default(cuid())
  publicSlug String?   @unique @default(cuid())
  date       DateTime  @db.Date
  mealType   MealType
  cutoffTime DateTime? // UTC DateTime (display in IST via utcToISTTimeString)

  thalis       DailyMenuThali[]
  sabjiOptions DailyMenuSabjiOption[]
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date, mealType])
}

// Which thalis are available on a given daily menu
model DailyMenuThali {
  id               String    @id @default(cuid())
  menu             DailyMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId           String
  thali            Thali     @relation(fields: [thaliId], references: [id], onDelete: Restrict)
  thaliId          String
  minSabjiRequired Int       @default(1)

  @@unique([menuId, thaliId])
}

// Which sabji options are available per category per daily menu
model DailyMenuSabjiOption {
  id         String        @id @default(cuid())
  menu       DailyMenu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuId     String
  category   ThaliCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryId String
  product    Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId  String

  @@unique([menuId, categoryId, productId])
}

// -----------------------------------------
// MENU TEMPLATE
// -----------------------------------------
model MenuTemplate {
  id         String   @id @default(cuid())
  name       String   @unique
  mealType   MealType
  cutoffTime String?
  thaliIds   String[]
  sabjiConfig Json    @default("[]")
  createdAt  DateTime @default(now())
}

// -----------------------------------------
// USER DEVICE (persistent login per device)
// -----------------------------------------
model UserDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceHash String   // SHA-256(userAgent + screenWidth + timezone)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, deviceHash])
  @@index([userId])
}

// -----------------------------------------
// DEVICE FINGERPRINT (security layer -- new)
// -----------------------------------------
model DeviceFingerprint {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprintHash String              // sha256(clientVisitorId|userAgent|serverSalt)
  userAgent       String
  ipAtFirstSeen   String
  firstSeenAtUtc  DateTime @default(now())
  lastSeenAtUtc   DateTime @updatedAt
  isTrusted       Boolean  @default(false) // true after first successful full login
  isBlocked       Boolean  @default(false)
  blockedReason   String?

  @@unique([userId, fingerprintHash])
  @@index([fingerprintHash])
  @@index([isBlocked])
}

// -----------------------------------------
// OTP VERIFICATION (provider-agnostic -- new)
// -----------------------------------------
enum OtpPurpose {
  REGISTER
  LOGIN
  FORGOT_PIN
  STAFF_LOGIN
}

model OtpVerification {
  id             String     @id @default(cuid())
  mobile         String
  purpose        OtpPurpose
  verificationId String              // returned by Message Central "send" call
  userId         String?             // linked once a User draft exists
  attempts       Int        @default(0)
  expiresAtUtc   DateTime
  consumedAtUtc  DateTime?
  createdAtUtc   DateTime   @default(now())

  @@index([mobile, purpose])
}

// -----------------------------------------
// CUSTOMER SESSIONS (JWT refresh tokens -- new)
// -----------------------------------------
model CustomerSession {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash      String    @unique   // SHA-256 of the raw refresh token
  deviceFingerprintHash String
  createdAtUtc          DateTime  @default(now())
  expiresAtUtc          DateTime            // now + 100 days
  revokedAtUtc          DateTime?
  replacedBySessionId   String?             // set on rotation, enables reuse detection

  @@index([userId])
}

// -----------------------------------------
// RATE LIMIT LEDGER (new)
// -----------------------------------------
enum RateLimitScope {
  MOBILE
  IP
  DEVICE
}

enum RateLimitAction {
  SEND_OTP_REGISTER
  SEND_OTP_LOGIN
  SEND_OTP_FORGOT_PIN
  SEND_OTP_STAFF_LOGIN
  VERIFY_OTP
  LOGIN_PIN_ATTEMPT
  ADD_COMPANY
}

model RateLimitEvent {
  id           String          @id @default(cuid())
  scopeType    RateLimitScope
  scopeKey     String          // the mobile / ip / fingerprintHash value
  action       RateLimitAction
  createdAtUtc DateTime        @default(now())

  @@index([scopeType, scopeKey, action, createdAtUtc])
}

// -----------------------------------------
// SYSTEM SETTINGS (DB-backed config -- new)
// -----------------------------------------
model SystemSetting {
  id           String   @id @default(cuid())
  key          String   @unique // e.g. "MAX_THALI_PER_ORDER"
  value        String            // stored as string, parsed by consumer
  updatedAtUtc DateTime @updatedAt
}

// -----------------------------------------
// ORDER STATUS ENUM
// -----------------------------------------
enum OrderStatus {
  PENDING    // just placed
  CONFIRMED  // admin acknowledged
  DELIVERED  // marked delivered
  CANCELLED  // admin cancelled (no user cancellation)
}

// -----------------------------------------
// ORDER
// -----------------------------------------
model Order {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  menuId       String
  menu         DailyMenu   @relation(fields: [menuId], references: [id], onDelete: Restrict)
  thaliId      String
  thali        Thali       @relation(fields: [thaliId], references: [id], onDelete: Restrict)
  // Delivery address (nullable for backwards compat with existing orders)
  addressId    String?
  address      Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  selectedSabji  OrderSabji[]
  selectedAddons OrderAddon[]
  // Multi-thali support (new)
  thaliItems   OrderThaliItem[]
  addonItems   OrderAddonItem[]
  totalAmount  Float
  status       OrderStatus @default(PENDING)
  note         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([menuId])
  @@index([createdAt])
}

// Selected sabji items per order (legacy single-thali)
model OrderSabji {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, productId])
}

// Selected add-on items per order (legacy single-thali, price snapshot)
model OrderAddon {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  price     Float   // price snapshot at time of order
  quantity  Int     @default(1)

  @@unique([orderId, productId])
}

// -----------------------------------------
// MULTI-THALI ORDER ITEMS (new)
// -----------------------------------------

// One line per thali type in a multi-thali order (each with its own sabji)
model OrderThaliItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  thaliId        String
  thali          Thali   @relation(fields: [thaliId], references: [id], onDelete: Restrict)
  sabjiProductId String  // The sabji chosen for THIS specific thali line
  sabjiProduct   Product @relation(fields: [sabjiProductId], references: [id], onDelete: Restrict)
  quantity       Int     @default(1)
}

// One line per add-on product in a multi-thali order
model OrderAddonItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addonProductId String
  addonProduct   Product @relation(fields: [addonProductId], references: [id], onDelete: Restrict)
  quantity       Int
  priceSnapshot  Float   // price at time of order
}

// -----------------------------------------
// ENUMS
// -----------------------------------------
enum MealType {
  LUNCH
  DINNER
}

// -----------------------------------------
// BAN HISTORY (audit trail)
// -----------------------------------------
model BanHistory {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action          String    // "BLOCKED" | "UNBLOCKED" | "BANNED" | "UNBANNED"
  reason          String?
  actedByStaffId  String    // AppUser ID
  createdAt       DateTime  @default(now())

  @@index([userId])
}

// -----------------------------------------
// ADMIN AUDIT LOG
// -----------------------------------------
model AdminAuditLog {
  id              String   @id @default(cuid())
  actedByStaffId  String
  action          String   // "COMPANY_VERIFIED" | "COMPANY_FLAGGED_FAKE" | "MEAL_SETTINGS_UPDATED"
  targetType      String   // "Company" | "MealSettings" | "User" | "Device"
  targetId        String
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([targetType, targetId])
}

// -----------------------------------------
// MEAL SETTINGS (global default configs)
// -----------------------------------------
model MealSettings {
  id               String    @id @default(cuid())
  mealType         MealType  @unique
  cutoffTime       String    // "10:30" 24h local time (IST)
  menuVisibleFrom  String    // "18:00"
  isOrderingOpen   Boolean   @default(true)
  updatedAt        DateTime  @updatedAt
}

// -----------------------------------------
// STAFF USER (OTP authenticated Admin/Staff -- new)
// -----------------------------------------
enum StaffRole {
  ADMIN
  STAFF
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

model StaffUser {
  id                String        @id @default(cuid())
  name              String
  mobile            String        @unique
  role              StaffRole     @default(STAFF)
  permissions       String[]      @default([]) // Flat permission catalog
  status            StaffStatus   @default(ACTIVE)

  createdByAdminId  String?
  createdBy         StaffUser?    @relation("StaffCreatedBy", fields: [createdByAdminId], references: [id])
  staffCreated      StaffUser[]   @relation("StaffCreatedBy")

  lastLoginAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([role])
  @@index([status])
}

