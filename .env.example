DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
JWT_SECRET="your_jwt_secret_here"
JWT_EXPIRES_IN="8h"
NEXT_PUBLIC_APP_NAME="VD's Hunger Hub"

# Message Central VerifyNow OTP credentials
# Get these from your Message Central / VerifyNow dashboard
MESSAGECENTRAL_BASE_URL="https://cpaas.messagecentral.com"
MESSAGECENTRAL_CUSTOMER_ID="your_customer_id_here"
MESSAGECENTRAL_AUTH_TOKEN="your_auth_token_here"

# Server-side pepper for hashing the client fingerprint.
# Generate with: openssl rand -hex 32
# CRITICAL: This MUST be set in production. The default "default_salt" fallback
# in customer-auth.ts is functionally equivalent to no salt — set this value.
# Rotate ONLY if you intentionally want to invalidate every existing DeviceFingerprint
# row (rotating logs every device out of "trusted" status simultaneously).
DEVICE_FINGERPRINT_SERVER_SALT="generate_a_long_random_string_here"
